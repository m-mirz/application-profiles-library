# https://ap-con.cim4.eu/SecurityAnalysisResult-Complex/2.5#PowerFlowResult-voltageAndAngle
# PowerFlowResult-voltageAndAngle
# PowerFlowResult.valueV and PowerFlowResult.valueAngle shall not be instantiated if PowerFlowResult is associated with ACDCTerminal or PowerTransferCorridor.

PREFIX adms:    <http://www.w3.org/ns/adms#>
PREFIX cim:     <https://cim.ucaiug.io/ns#>
#PREFIX cim:    <http://iec.ch/TC57/CIM100#>
PREFIX cim16:   <http://iec.ch/TC57/2013/CIM-schema-cim16#>
PREFIX cim17:   <http://iec.ch/TC57/CIM100#>
PREFIX dcat:    <http://www.w3.org/ns/dcat#>
PREFIX dcatcim: <https://cim4.eu/ns/dcatcim#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dm:      <http://iec.ch/TC57/61970-552/DifferenceModel/1#>
PREFIX eu:      <https://cim.ucaiug.io/ns/eu#>
#PREFIX eu:     <http://iec.ch/TC57/CIM100-European#>
PREFIX md:      <http://iec.ch/TC57/61970-552/ModelDescription/1#>
PREFIX nc:      <https://cim4.eu/ns/nc#>
PREFIX prov:    <http://www.w3.org/ns/prov#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>


			SELECT  $this  
			WHERE {  
		
        BIND(EXISTS{$this nc:PowerFlowResult.valueV ?o1} AS ?hasvalueV).
		BIND(EXISTS{$this nc:PowerFlowResult.valueAngle ?o2} AS ?hasvalueAngle).
		BIND(EXISTS{$this nc:PowerFlowResult.ACDCTerminal ?o3} AS ?hasT).
		BIND(EXISTS{$this nc:PowerFlowResult.PowerTransferCorridor ?o4} AS ?hasPTC).

        FILTER ((?hasvalueV=true || ?hasvalueAngle=true) && (?hasT=true || ?hasPTC=true) ).
			}