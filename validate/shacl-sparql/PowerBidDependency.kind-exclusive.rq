# https://ap-con.cim4.eu/StateInstructionSchedule-Complex/2.4#PowerBidDependency.kind-exclusive
# PowerBidDependency.kind-exclusive
# If PowerBidDependency.kind is set to PowerBidDependencyKind.exclusive, the following attributes shall not be defined: PowerBidDependency.overlap, PowerBidDependency.startToStartLag, PowerBidDependency.finishToStartLag, PowerBidDependency.finishToFinishLag.

PREFIX adms:    <http://www.w3.org/ns/adms#>
PREFIX cim:     <https://cim.ucaiug.io/ns#>
#PREFIX cim:    <http://iec.ch/TC57/CIM100#>
PREFIX cim16:   <http://iec.ch/TC57/2013/CIM-schema-cim16#>
PREFIX cim17:   <http://iec.ch/TC57/CIM100#>
PREFIX dcat:    <http://www.w3.org/ns/dcat#>
PREFIX dcatcim: <https://cim4.eu/ns/dcatcim#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dm:      <http://iec.ch/TC57/61970-552/DifferenceModel/1#>
PREFIX eu:      <https://cim.ucaiug.io/ns/eu#>
#PREFIX eu:     <http://iec.ch/TC57/CIM100-European#>
PREFIX md:      <http://iec.ch/TC57/61970-552/ModelDescription/1#>
PREFIX nc:      <https://cim4.eu/ns/nc#>
PREFIX prov:    <http://www.w3.org/ns/prov#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>


			SELECT  $this  
			WHERE {  
		$this nc:PowerBidDependency.kind nc:PowerBidDependencyKind.exclusive.
		
		BIND(EXISTS{$this nc:PowerBidDependency.overlap ?op} AS ?hasop).	
		BIND(EXISTS{$this nc:PowerBidDependency.startToStartLag ?sts} AS ?hassts).
		BIND(EXISTS{$this nc:PowerBidDependency.finishToStartLag ?fts} AS ?hasfts).
		BIND(EXISTS{$this nc:PowerBidDependency.finishToFinishLag ?ftf} AS ?hasftf).
		
        FILTER (?hasop=true || ?hassts=true || ?hasfts=true || ?hasftf=true).
			}