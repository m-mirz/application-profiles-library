        sh:nodeKind     sh:BlankNode;
        sh:order        1;
        sh:path         ( dm:DifferenceModel.forwardDifferences cim:Statements.predicate );
        sh:severity     sh:Violation .

fh:Statements.predicate-cardinality
        rdf:type        sh:PropertyShape;
