fh:DifferenceModel-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              fh:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              2;
        sh:property           [ sh:path  dm:DifferenceModel.forwardDifferences ];
        sh:property           [ sh:path  dm:DifferenceModel.reverseDifferences ];
        sh:property           [ sh:path  dm:DifferenceModel.preconditions ];
        sh:property           [ sh:path  md:Model.modelingAuthoritySet ];
        sh:property           [ sh:path  md:Model.profile ];
        sh:property           [ sh:path  md:Model.scenarioTime ];
        sh:property           [ sh:path  md:Model.version ];
        sh:property           [ sh:path  md:Model.created ];
        sh:property           [ sh:path  md:Model.DependentOn ];
        sh:property           [ sh:path  md:Model.Supersedes ];
        sh:property           [ sh:path  md:Model.description ];
        sh:severity           sh:Info;
        sh:targetClass        dm:DifferenceModel .

fh:DifferenceModel  rdf:type  sh:NodeShape;
        sh:property     fh:Model.description-datatype , fh:Model.description-cardinality , fh:Model.created-datatype , fh:Model.created-cardinality , fh:Model.version-datatype , fh:Model.version-cardinality , fh:Model.scenarioTime-datatype , fh:Model.scenarioTime-cardinality , fh:Model.profile-datatype , fh:Model.profile-cardinality , fh:DifferenceModel.forwardDifferences-cardinality , fh:DifferenceModel.forwardDifferences-datatype , fh:Statements.object-cardinality , fh:Statements.object-datatype , fh:Statements.predicate-cardinality , fh:Statements.predicate-datatype , fh:Statements.subject-cardinality , fh:Statements.subject-datatype , fh:DifferenceModel.reverseDifferences-cardinality , fh:DifferenceModel.reverseDifferences-datatype , fh:DifferenceModel.preconditions-cardinality , fh:DifferenceModel.preconditions-datatype , fh:Model.modelingAuthoritySet-cardinality , fh:Model.modelingAuthoritySet-datatype;
        sh:targetClass  dm:DifferenceModel .

fh:Model.SupersededBy-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        fh:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        2;
        sh:path         md:Model.SupersededBy;
        sh:severity     sh:Violation .

fh:Model.SupersededBy-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          fh:Model.SupersededBy-propertyInverse;
        sh:targetSubjectsOf  md:Model.SupersededBy .

fh:Model.description-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        fh:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "Model.description-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        4;
        sh:path         md:Model.description;
        sh:severity     sh:Violation .

fh:Model.description-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        fh:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "Model.description-cardinality";
        sh:order        9;
        sh:path         md:Model.description;
        sh:severity     sh:Violation .

fh:Model.Supersedes-nodeKind
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the node kind of the association at the used direction.";
        sh:group        fh:AssociationsGroup;
        sh:message      "The node kind shall be IRI (rdf:resource is expected).";
        sh:name         "Model.Supersedes-nodeKind";
        sh:nodeKind     sh:IRI;
        sh:order        2;
        sh:path         md:Model.Supersedes;
        sh:severity     sh:Violation .

fh:Model.Supersedes-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     fh:Model.Supersedes-nodeKind;
        sh:targetClass  dm:DifferenceModel , md:FullModel .

fh:Model.Depending-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        fh:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        1;
        sh:path         md:Model.Depending;
        sh:severity     sh:Violation .

fh:Model.Depending-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          fh:Model.Depending-propertyInverse;
        sh:targetSubjectsOf  md:Model.Depending .

fh:Model.DependentOn-nodeKind
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the node kind of the association at the used direction.";
        sh:group        fh:AssociationsGroup;
        sh:message      "The node kind shall be IRI (rdf:resource is expected).";
        sh:name         "Model.DependentOn-nodeKind";
        sh:nodeKind     sh:IRI;
        sh:order        1;
        sh:path         md:Model.DependentOn;
        sh:severity     sh:Violation .

fh:Model.DependentOn-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     fh:Model.DependentOn-nodeKind;
        sh:targetClass  dm:DifferenceModel , md:FullModel .

