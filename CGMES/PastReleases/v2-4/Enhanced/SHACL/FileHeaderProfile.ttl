fh:FullModel-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              fh:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  md:Model.modelingAuthoritySet ];
        sh:property           [ sh:path  md:Model.profile ];
        sh:property           [ sh:path  md:Model.scenarioTime ];
        sh:property           [ sh:path  md:Model.version ];
        sh:property           [ sh:path  md:Model.created ];
        sh:property           [ sh:path  md:Model.DependentOn ];
        sh:property           [ sh:path  md:Model.Supersedes ];
        sh:property           [ sh:path  md:Model.description ];
        sh:severity           sh:Info;
        sh:targetClass        md:FullModel .

fh:FullModel  rdf:type  sh:NodeShape;
        sh:property     fh:Model.description-datatype , fh:Model.description-cardinality , fh:Model.created-datatype , fh:Model.created-cardinality , fh:Model.version-datatype , fh:Model.version-cardinality , fh:Model.scenarioTime-datatype , fh:Model.scenarioTime-cardinality , fh:Model.profile-datatype , fh:Model.profile-cardinality , fh:Model.modelingAuthoritySet-datatype , fh:Model.modelingAuthoritySet-cardinality;
        sh:targetClass  md:FullModel .

fh:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        fh:ProfileClassesGroup;
        sh:in           ( md:FullModel dm:DifferenceModel md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
		sh:deactivated	true; 
        sh:severity     sh:Info .

fh:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          fh:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

fh:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

fh:AssociationsGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

fh:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

fh:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

fh:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

fh:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .

