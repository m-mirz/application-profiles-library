cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

sis:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        sis:ProfileClassesGroup;
        sh:in           ( nc:PowerShiftKeyDistribution nc:AssessedElementRegularSchedule nc:VoltageAngleSchedule nc:AssessedElementTimePoint nc:FuelStorageSchedule nc:StageTriggerSchedule nc:UnitCostTimePoint nc:ReservoirTimePoint nc:ParticipationFactorTimePoint nc:GenericAvailableSchedule nc:HourPeriod nc:GenericValueTimePoint nc:PowerShiftKeySchedule nc:StageTriggerTimePoint nc:InfeedLimitSchedule nc:RemedialActionGroupSchedule nc:PowerRemedialActionSchedule nc:GridStateIntensitySchedule nc:VoltageAngleTimePoint nc:ContingencySchedule nc:ContingencyTimePoint nc:AvailabilityTimePoint nc:RemedialActionGroupTimePoint nc:GenericSequenceSchedule cim:Season nc:GenericEnablingSchedule nc:AssessedElementSchedule nc:BaseCaseCurrentLimitTimePoint nc:RemedialActionSchemeSchedule nc:GridStateAlterationSchedule nc:SequenceTimePoint nc:GridStateAlterationTimePoint nc:InfeedLimitTimePoint nc:EnablingTimePoint nc:ReservoirSchedule nc:RemedialActionSchemeTimePoint nc:GenericValueSchedule nc:PowerRemedialActionTimePoint nc:HourPattern nc:UnitCostSchedule nc:PowerBidDependency nc:PowerBidSchedule nc:FuelStorageTimePoint nc:AssessedElementRegularTimePoint nc:PowerBidScheduleTimePoint nc:BaseCaseCurrentLimitSchedule md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

sis:AllowedClasses-node
