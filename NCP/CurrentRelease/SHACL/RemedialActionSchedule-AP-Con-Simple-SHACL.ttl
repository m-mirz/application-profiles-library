ras:ProposingRemedialActionScheduleShare.ProposingEntity-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        ras:AssociationsGroup;
        sh:in           ( nc:DirectCurrentSystemOperator nc:TransmissionSystemOperator nc:ClosedDistributionSystemOperator nc:DistributionSystemOperator );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "ProposingRemedialActionScheduleShare.ProposingEntity-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        26;
        sh:path         ( nc:ProposingRemedialActionScheduleShare.ProposingEntity rdf:type );
        sh:severity     sh:Violation .

ras:ProposingRemedialActionScheduleShare.ProposingEntity-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     ras:ProposingRemedialActionScheduleShare.ProposingEntity-valueType;
        sh:targetClass  nc:ProposingRemedialActionScheduleShare .

ras:ProposingRemedialActionScheduleShare.ProposingEntity-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        ras:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "ProposingRemedialActionScheduleShare.ProposingEntity-cardinality";
        sh:order        111;
        sh:path         nc:ProposingRemedialActionScheduleShare.ProposingEntity;
        sh:severity     sh:Violation .

