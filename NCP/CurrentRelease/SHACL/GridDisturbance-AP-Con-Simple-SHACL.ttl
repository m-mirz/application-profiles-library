gd:FaultOutage.Fault-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:Fault;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gd:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim18:Fault";
        sh:name         "FaultOutage.Fault-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        159;
        sh:path         nc:FaultOutage.Fault;
        sh:severity     sh:Violation .

gd:FaultOutage.Fault-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        gd:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "FaultOutage.Fault-cardinality";
        sh:order        655;
        sh:path         nc:FaultOutage.Fault;
        sh:severity     sh:Violation .

