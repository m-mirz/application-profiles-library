gd:FaultOutage-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              gd:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              94;
        sh:property           [ sh:path  nc:FaultOutage.Fault ];
        sh:property           [ sh:path  nc:FaultOutage.Outage ];
        sh:property           [ sh:path  nc:FaultOutage.isMainFault ];
        sh:property           [ sh:path  nc:FaultOutage.mRID ];
        sh:severity           sh:Info;
        sh:targetClass        nc:FaultOutage .

