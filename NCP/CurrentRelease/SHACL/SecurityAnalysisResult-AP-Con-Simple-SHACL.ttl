sar:RemedialActionApplied.RemedialAction-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     sar:RemedialActionApplied.RemedialAction-valueType;
        sh:targetClass  nc:RemedialActionApplied .

sar:RemedialActionApplied.RemedialAction-cardinality
        rdf:type        sh:PropertyShape;
