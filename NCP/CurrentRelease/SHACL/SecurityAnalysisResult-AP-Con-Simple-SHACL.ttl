sar:RemedialActionApplied.StageForRemedialActionScheme-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:Stage;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:Stage";
        sh:name         "RemedialActionApplied.StageForRemedialActionScheme-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        7;
        sh:path         nc:RemedialActionApplied.StageForRemedialActionScheme;
