sar:BaseCasePowerFlowResult-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              sar:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              3;
        sh:property           [ sh:path  nc:PowerFlowResult.ACDCTerminal ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueA ];
        sh:property           [ sh:path  nc:PowerFlowResult.value ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueAngle ];
        sh:property           [ sh:path  nc:PowerFlowResult.atTime ];
        sh:property           [ sh:path  nc:PowerFlowResult.TopologicalNode ];
        sh:property           [ sh:path  nc:PowerFlowResult.PowerTransferCorridor ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueV ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueW ];
        sh:property           [ sh:path  nc:PowerFlowResult.OperationalLimit ];
        sh:property           [ sh:path  nc:PowerFlowResult.absoluteValue ];
        sh:property           [ sh:path  nc:PowerFlowResult.isViolation ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueVA ];
        sh:property           [ sh:path  nc:PowerFlowResult.ReportedByRegion ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueVAR ];
        sh:severity           sh:Info;
        sh:targetClass        nc:BaseCasePowerFlowResult .

sar:BaseCasePowerFlowResult
        rdf:type        sh:NodeShape;
        sh:property     sar:PowerFlowResult.ACDCTerminal-cardinality , sar:PowerFlowResult.valueVAR-datatype , sar:PowerFlowResult.valueVAR-cardinality , sar:PowerFlowResult.ReportedByRegion-cardinality , sar:PowerFlowResult.valueVA-datatype , sar:PowerFlowResult.valueVA-cardinality , sar:PowerFlowResult.isViolation-datatype , sar:PowerFlowResult.isViolation-cardinality , sar:PowerFlowResult.absoluteValue-datatype , sar:PowerFlowResult.absoluteValue-cardinality , sar:PowerFlowResult.OperationalLimit-cardinality , sar:PowerFlowResult.valueW-datatype , sar:PowerFlowResult.valueA-cardinality , sar:PowerFlowResult.valueA-datatype , sar:PowerFlowResult.value-cardinality , sar:PowerFlowResult.value-datatype , sar:PowerFlowResult.valueAngle-cardinality , sar:PowerFlowResult.valueAngle-datatype , sar:PowerFlowResult.atTime-cardinality , sar:PowerFlowResult.atTime-datatype , sar:PowerFlowResult.TopologicalNode-cardinality , sar:PowerFlowResult.TopologicalNode-valueType , sar:PowerFlowResult.PowerTransferCorridor-cardinality , sar:PowerFlowResult.valueV-cardinality , sar:PowerFlowResult.valueV-datatype , sar:PowerFlowResult.valueW-cardinality;
        sh:targetClass  nc:BaseCasePowerFlowResult .

sar:RemedialActionApplied.PowerFlowResult-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:in           ( nc:ContingencyPowerFlowResult nc:BaseCasePowerFlowResult );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "RemedialActionApplied.PowerFlowResult-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        9;
        sh:path         ( nc:RemedialActionApplied.PowerFlowResult rdf:type );
        sh:severity     sh:Violation .

sar:RemedialActionApplied.PowerFlowResult-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     sar:RemedialActionApplied.PowerFlowResult-valueType;
        sh:targetClass  nc:RemedialActionApplied .

sar:RemedialActionApplied.PowerFlowResult-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        sar:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "RemedialActionApplied.PowerFlowResult-cardinality";
        sh:order        21;
        sh:path         nc:RemedialActionApplied.PowerFlowResult;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.RemedialAction-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:in           ( nc:RedispatchRemedialAction nc:CountertradeRemedialAction nc:GridStateAlterationRemedialAction nc:SchemeRemedialAction nc:AvailabilityRemedialAction );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
