        sh:property           [ sh:path  nc:PowerFlowResult.isViolation ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueVA ];
        sh:property           [ sh:path  nc:PowerFlowResult.ReportedByRegion ];
        sh:severity           sh:Info;
        sh:targetClass        nc:ContingencyPowerFlowResult .

sar:ContingencyPowerFlowResult
        rdf:type        sh:NodeShape;
        sh:property     sar:PowerFlowResult.ACDCTerminal-cardinality , sar:PowerFlowResult.valueVAR-datatype , sar:PowerFlowResult.valueVAR-cardinality , sar:PowerFlowResult.ReportedByRegion-cardinality , sar:PowerFlowResult.valueVA-datatype , sar:PowerFlowResult.valueVA-cardinality , sar:PowerFlowResult.isViolation-datatype , sar:PowerFlowResult.isViolation-cardinality , sar:PowerFlowResult.absoluteValue-datatype , sar:PowerFlowResult.absoluteValue-cardinality , sar:PowerFlowResult.OperationalLimit-cardinality , sar:PowerFlowResult.valueW-datatype , sar:PowerFlowResult.valueW-cardinality , sar:ContingencyPowerFlowResult.Contingency-cardinality , sar:PowerFlowResult.valueA-cardinality , sar:PowerFlowResult.valueA-datatype , sar:PowerFlowResult.value-cardinality , sar:PowerFlowResult.value-datatype , sar:PowerFlowResult.valueAngle-cardinality , sar:PowerFlowResult.valueAngle-datatype , sar:PowerFlowResult.atTime-cardinality , sar:PowerFlowResult.atTime-datatype , sar:PowerFlowResult.TopologicalNode-cardinality , sar:PowerFlowResult.TopologicalNode-valueType , sar:PowerFlowResult.PowerTransferCorridor-cardinality , sar:PowerFlowResult.valueV-cardinality , sar:PowerFlowResult.valueV-datatype;
        sh:targetClass  nc:ContingencyPowerFlowResult .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

sar:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        sar:ProfileClassesGroup;
        sh:in           ( nc:ContingencyPowerFlowResult nc:RemedialActionApplied nc:BaseCasePowerFlowResult md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

sar:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          sar:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

sar:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

sar:AssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

sar:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

sar:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

sar:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

sar:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .
