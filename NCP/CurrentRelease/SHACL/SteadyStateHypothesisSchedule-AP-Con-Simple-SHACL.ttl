cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

shs:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        shs:ProfileClassesGroup;
        sh:in           ( nc:TapChangerControlRegularSchedule nc:SwitchTimePoint nc:RegulatingControlSchedule nc:CurrentLimitTimePoint nc:FuelStorageSchedule nc:BaseIrregularTimeSeries nc:RemedialActionSchemeSchedule nc:GridStateIntensitySchedule nc:EventSchedule nc:PowerSchedule nc:ApparentPowerLimitSchedule nc:SwitchRegularSchedule nc:BatteryUnitSchedule nc:TapScheduleTimePoint nc:StaticVarCompensatorSchedule nc:SynchronousMachineSchedule nc:CsConverterTimePoint nc:StaticVarCompensatorTimePoint nc:AsynchronousMachineTimePoint nc:ReservoirTimePoint nc:VsConverterTimePoint nc:EquivalentInjectionRegularSchedule nc:HourPeriod nc:AsynchronousMachineSchedule nc:SynchronousMachineRegularSchedule nc:SynchronousMachineTimePoint nc:EnergyConnectionSchedule nc:AsynchronousMachineRegularSchedule nc:VsConverterRegularSchedule nc:ControlAreaSchedule nc:VsConverterSchedule nc:GeneratingUnitSchedule nc:SwitchSchedule nc:InServiceRegularSchedule nc:ExternalNetworkInjectionRegularSchedule cim:Season nc:VoltageLimitTimePoint nc:CsConverterSchedule nc:ApparentPowerLimitTimePoint nc:EnergyConnectionRegularSchedule nc:FuelStorageRegularSchedule nc:ControlAreaTimePoint nc:ShuntCompensatorTimePoint nc:EnergyConnectionTimePoint nc:ExternalNetworkInjectionSchedule nc:ControlAreaRegularSchedule nc:InServiceSchedule nc:CurrentLimitSchedule nc:EquivalentInjectionTimePoint nc:TapRegularSchedule nc:ReservoirSchedule nc:BatteryUnitTimePoint nc:ReservoirRegularSchedule nc:TapSchedule nc:HourPattern nc:VoltageLimitSchedule nc:ExternalNetworkInjectionTimePoint nc:RegulatingControlRegularSchedule nc:InServiceTimePoint nc:EquivalentInjectionSchedule nc:FuelStorageTimePoint nc:RegulatingControlTimePoint nc:GeneratingUnitTimePoint nc:CsConverterRegularSchedule nc:TapChangerControlSchedule nc:ActivePowerLimitSchedule nc:ShuntCompensatorSchedule nc:ActivePowerLimitTimePoint md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

