iam:QualitativeRemedialActionImpact
        rdf:type        sh:NodeShape;
        sh:property     iam:RemedialActionImpact.mRID-datatype , iam:RemedialActionImpact.mRID-cardinality , iam:RemedialActionImpact.RemedialActionGroup-valueType , iam:RemedialActionImpact.RemedialActionGroup-cardinality , iam:RemedialActionImpact.impactQuantity-datatype , iam:RemedialActionImpact.impactQuantity-cardinality , iam:RemedialActionImpact.kind-datatype , iam:RemedialActionImpact.kind-cardinality , iam:RemedialActionImpact.RemedialAction-cardinality , iam:RemedialActionImpact.AssessingSystemOperator-cardinality;
        sh:targetClass  nc:QualitativeRemedialActionImpact .

iam:RemedialActionImpact.mRID-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        iam:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "RemedialActionImpact.mRID-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        13;
        sh:path         nc:RemedialActionImpact.mRID;
        sh:severity     sh:Violation .

iam:RemedialActionImpact.mRID-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        iam:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "RemedialActionImpact.mRID-cardinality";
        sh:order        31;
        sh:path         nc:RemedialActionImpact.mRID;
        sh:severity     sh:Violation .

iam:RemedialActionImpact.RemedialActionGroup-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:RemedialActionGroup;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        iam:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:RemedialActionGroup";
        sh:name         "RemedialActionImpact.RemedialActionGroup-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        13;
        sh:path         nc:RemedialActionImpact.RemedialActionGroup;
        sh:severity     sh:Violation .

iam:RemedialActionImpact.RemedialActionGroup-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        iam:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "RemedialActionImpact.RemedialActionGroup-cardinality";
        sh:order        30;
        sh:path         nc:RemedialActionImpact.RemedialActionGroup;
        sh:severity     sh:Violation .

iam:RemedialActionImpact.OwnerRemedialActionAssessment-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        iam:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        3;
        sh:path         nc:RemedialActionImpact.OwnerRemedialActionAssessment;
        sh:severity     sh:Violation .

iam:RemedialActionImpact.OwnerRemedialActionAssessment-inverseNodePresent
