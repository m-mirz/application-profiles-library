        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "dd6ce9e0-e99e-4d89-b0af-e21357fcd82e";
        dcterms:issued        "2025-09-11T16:32:23.844375900"^^xsd:dateTime;
        dcterms:language      "en-GB";
