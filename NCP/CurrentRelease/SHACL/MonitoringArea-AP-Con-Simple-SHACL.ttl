ma:SensitivityArea-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              ma:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              4;
        sh:property           [ sh:path  nc:InfluenceArea.voltageInfluenceFactor ];
        sh:property           [ sh:path  nc:InfluenceArea.identificationInfluenceFactor ];
        sh:property           [ sh:path  nc:InfluenceArea.filteringInfluenceFactor ];
        sh:property           [ sh:path  nc:MonitoringArea.SynchronousArea ];
        sh:property           [ sh:path  nc:MonitoringArea.Region ];
        sh:property           [ sh:path  nc:MonitoringArea.SystemOperator ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:severity           sh:Info;
        sh:targetClass        nc:SensitivityArea .

ma:SensitivityArea  rdf:type  sh:NodeShape;
        sh:property     ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ma:InfluenceArea.voltageInfluenceFactor-cardinality , ma:InfluenceArea.voltageInfluenceFactor-datatype , ma:InfluenceArea.identificationInfluenceFactor-cardinality , ma:InfluenceArea.identificationInfluenceFactor-datatype , ma:InfluenceArea.filteringInfluenceFactor-cardinality , ma:InfluenceArea.filteringInfluenceFactor-datatype , ma:MonitoringArea.SynchronousArea-cardinality , ma:MonitoringArea.SynchronousArea-valueType , ma:MonitoringArea.Region-cardinality , ma:MonitoringArea.SystemOperator-cardinality , ido:IdentifiedObject.name-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.mRID-datatype;
        sh:targetClass  nc:SensitivityArea .

ma:InfluenceArea.filteringInfluenceFactor-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:float;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        ma:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "InfluenceArea.filteringInfluenceFactor-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        5;
        sh:path         nc:InfluenceArea.filteringInfluenceFactor;
        sh:severity     sh:Violation .

ma:InfluenceArea.filteringInfluenceFactor-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ma:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "InfluenceArea.filteringInfluenceFactor-cardinality";
        sh:order        13;
        sh:path         nc:InfluenceArea.filteringInfluenceFactor;
        sh:severity     sh:Violation .

